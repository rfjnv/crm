# Server
PORT=3000
NODE_ENV=production

# Database
# Local: postgresql://user:pass@localhost:5432/crm_db
# Render: paste the same DATABASE_URL as your production web service (often the internal URL on Render).
# For scripts on your own PC, if the DB blocks external clients, open Inbound IP rules on the Render Postgres instance or use the External URL from the Connect menu.
DATABASE_URL=postgresql://crm_user:CHANGE_ME@localhost:5432/crm_db

# JWT (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=CHANGE-ME-generate-random-32-chars-minimum
JWT_REFRESH_SECRET=CHANGE-ME-generate-random-32-chars-minimum

# CORS
CORS_ORIGIN=https://your-domain.com

# Telegram (staff bot — same token as CRM notifications / linking)
TELEGRAM_BOT_TOKEN=
# Optional: public CRM URL for inline links in messages
# TELEGRAM_CRM_URL=https://www.polygraphbusinesscrm.app

# Telegram group chat IDs for automatic deal alerts (empty = disabled). Bot must be in each group.
# Для супергрупп id обычно -100 + девять цифр (поле "id" в @RawDataBot / message.chat.id).
# TELEGRAM_GROUP_WAREHOUSE_CHAT_ID=
# TELEGRAM_GROUP_PRODUCTION_CHAT_ID=
# TELEGRAM_GROUP_FINANCE_CHAT_ID=
