  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ==================== ANALYTICS SNAPSHOTS ====================

model MonthlySnapshot {
  id        String   @id @default(uuid())
  year      Int
  month     Int      // 0 = full-year snapshot, 1-12 = per-month
  scope     String   @default("admin")
  type      String   // 'overview' | 'extended' | 'data-quality' | 'exchange' | 'prepayments' | 'cashflow' | 'month-detail'
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([year, month, scope, type])
  @@index([year, month])
  @@map("monthly_snapshots")
}

// ==================== AI ASSISTANT CHATS ====================

model AiChat {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String   @default("Новый чат")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiChatMessage[]

  @@index([userId, updatedAt])
  @@map("ai_chats")
}

model AiChatMessage {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  role      String
  content   String   @db.Text
  sql       String?  @db.Text
  entities  Json?
  isError   Boolean  @default(false) @map("is_error")
  createdAt DateTime @default(now()) @map("created_at")

  chat AiChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@map("ai_chat_messages")
}

model AiTrainingRule {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author User @relation("AiTrainingRuleAuthor", fields: [createdBy], references: [id])

  @@map("ai_training_rules")
}

// ==================== FOREIGN TRADE (ВЭД) ====================

/** Поставщик (зеркало Client, но для закупок). */
model Supplier {
  id            String            @id @default(uuid())
  companyName   String            @map("company_name")
  country       String?
  contactPerson String?           @map("contact_person")
  email         String?
  phone         String?
  currency      SupplierCurrency  @default(USD)
  incoterms     Incoterms?
  paymentTerms  String?           @map("payment_terms")
  bankSwift     String?           @map("bank_swift")
  iban          String?
  notes         String?           @db.Text
  isArchived    Boolean           @default(false) @map("is_archived")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  products     Product[]
  importOrders ImportOrder[]

  @@index([isArchived])
  @@index([country])
  @@map("suppliers")
}

/** Импортный (закупочный) заказ у поставщика. */
model ImportOrder {
  id              String             @id @default(uuid())
  number          String             @unique
  supplierId      String             @map("supplier_id")
  createdById     String             @map("created_by_id")
  status          ImportOrderStatus  @default(DRAFT)
  currency        SupplierCurrency   @default(USD)
  orderDate       DateTime           @map("order_date")
  etd             DateTime?
  eta             DateTime?
  containerNumber String?            @map("container_number")
  invoiceNumber   String?            @map("invoice_number")
  /** Курс валюты на дату инвойса (UZS per 1 unit) */
  invoiceRate     Decimal?           @db.Decimal(15, 6) @map("invoice_rate")
  /** Итог по позициям в валюте заказа */
  totalAmount     Decimal            @default(0) @db.Decimal(15, 2) @map("total_amount")
  /** Итог в UZS по invoiceRate (MVP-4) */
  totalAmountUzs  Decimal?           @db.Decimal(18, 2) @map("total_amount_uzs")
  /** Сумма накладных расходов по заказу в UZS (фрахт, таможня, страховка…) — MVP-4 */
  overheadUzs     Decimal            @default(0) @db.Decimal(18, 2) @map("overhead_uzs")
  /** Себестоимость в UZS с учётом overhead — MVP-4 */
  landedCostUzs   Decimal?           @db.Decimal(18, 2) @map("landed_cost_uzs")
  notes           String?            @db.Text
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  supplier    Supplier                @relation(fields: [supplierId], references: [id])
  createdBy   User                    @relation("ImportOrderCreator", fields: [createdById], references: [id])
  items       ImportOrderItem[]
  attachments ImportOrderAttachment[]
  expenses    Expense[]               @relation("ImportOrderExpenses")

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@index([eta])
  @@map("import_orders")
}

model ImportOrderItem {
  id            String   @id @default(uuid())
  importOrderId String   @map("import_order_id")
  productId     String   @map("product_id")
  qty           Decimal  @db.Decimal(12, 3)
  unitPrice     Decimal  @db.Decimal(12, 2) @map("unit_price")
  lineTotal     Decimal  @db.Decimal(15, 2) @map("line_total")
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  importOrder ImportOrder @relation(fields: [importOrderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@index([importOrderId])
  @@index([productId])
  @@map("import_order_items")
}

model ImportOrderAttachment {
  id            String             @id @default(uuid())
  importOrderId String             @map("import_order_id")
  documentType  ImportDocumentType @default(OTHER) @map("document_type")
  filename      String
  path          String
  mimeType      String             @map("mime_type")
  size          Int
  uploadedBy    String             @map("uploaded_by")
  createdAt     DateTime           @default(now()) @map("created_at")

  importOrder ImportOrder @relation(fields: [importOrderId], references: [id], onDelete: Cascade)
  uploader    User        @relation("ImportOrderAttachmentUploader", fields: [uploadedBy], references: [id])

  @@index([importOrderId])
  @@index([documentType])
  @@map("import_order_attachments")
}

/// Курсы валют ЦБ РУз (MVP-3). Источник: https://cbu.uz
/// Используются для автоподстановки invoiceRate в ImportOrder по orderDate.
model ExchangeRate {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  currency  String
  rate      Decimal  @db.Decimal(18, 6)
  nominal   Int      @default(1)
  source    String   @default("CBU")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date, currency])
  @@index([date])
  @@index([currency])
  @@map("exchange_rates")
}
