generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  MANAGER
  HR
  ACCOUNTANT
  WAREHOUSE
  WAREHOUSE_MANAGER
  DRIVER
  LOADER
  FOREIGN_TRADE
}

enum DealStatus {
  NEW
  IN_PROGRESS
  WAITING_STOCK_CONFIRMATION
  STOCK_CONFIRMED
  WAITING_FINANCE
  FINANCE_APPROVED
  ADMIN_APPROVED
  READY_FOR_SHIPMENT
  SHIPMENT_ON_HOLD
  SHIPPED
  PENDING_APPROVAL
  CLOSED
  CANCELED
  REJECTED
  REOPENED
  // New workflow statuses
  WAITING_WAREHOUSE_MANAGER
  PENDING_ADMIN
  READY_FOR_LOADING
  LOADING_ASSIGNED
  READY_FOR_DELIVERY
  IN_DELIVERY
}

enum DeliveryType {
  SELF_PICKUP
  YANDEX
  DELIVERY
}

enum ConversationType {
  SALES
  WAREHOUSE
  ACCOUNTING
  SHIPMENT
}

enum MovementType {
  IN
  OUT
  CORRECTION
}

enum PaymentType {
  FULL
  PARTIAL
  INSTALLMENT
}

enum PaymentMethod {
  CASH
  TRANSFER
  PAYME
  QR
  CLICK
  TERMINAL
  INSTALLMENT
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum ClientCreditStatus {
  NORMAL
  SATISFACTORY
  NEGATIVE
}

enum ClientStockEventType {
  ADD
  RESERVE_TO_DEAL
  CORRECTION
}

enum AuditAction {
  CREATE
  UPDATE
  UPDATE_CLIENT
  DELETE
  ARCHIVE
  RESTORE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  NOTIFICATION_BROADCAST
  PAYMENT_CREATE
  PAYMENT_UPDATE
  PAYMENT_DELETE
  STOCK_WRITE_OFF
  OVERRIDE_UPDATE
  OVERRIDE_DELETE
}

enum NotificationSeverity {
  INFO
  WARNING
  URGENT
}

enum ContractType {
  ANNUAL
  ONE_TIME
}

enum SupplierCurrency {
  USD
  EUR
  CNY
  RUB
  UZS
}

enum Incoterms {
  EXW
  FCA
  FOB
  CFR
  CIF
  DAP
  DDP
}

enum ImportOrderStatus {
  DRAFT
  ORDERED
  IN_PRODUCTION
  SHIPPED
  IN_TRANSIT
  AT_CUSTOMS
  CLEARED
  RECEIVED
  CANCELED
}

enum ImportDocumentType {
  INVOICE
  PACKING_LIST
  BILL_OF_LADING
  CMR
  CERT_OF_ORIGIN
  CUSTOMS_DECLARATION
  SWIFT
  OTHER
}

// ==================== USERS & AUTH ====================

model User {
  id          String   @id @default(uuid())
  login       String   @unique
  password    String
  fullName    String   @map("full_name")
  /** Отдел / подразделение (для аналитики и матрицы клиентов) */
  department  String?  @map("department")
  role        Role     @default(MANAGER)
  permissions String[] @default([])
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sessions           Session[]
  clients            Client[]           @relation("ClientManager")
  deals              Deal[]             @relation("DealManager")
  archivedDeals      Deal[]             @relation("DealArchivedBy")
  comments           DealComment[]
  auditLogs          AuditLog[]
  confirmedItems     DealItem[]         @relation("ItemConfirmedBy")
  shipments          Shipment[]         @relation("ShippedBy")
  notificationsReceived  Notification[]      @relation("NotificationRecipient")
  notificationsSent      Notification[]      @relation("NotificationSender")
  notificationBatches    NotificationBatch[] @relation("BatchCreatedBy")
  paymentsMade           Payment[]           @relation("PaymentCreator")
  paymentsReceived       Payment[]           @relation("PaymentReceiver")
  lastSeenAt         DateTime?        @map("last_seen_at")
  messagesSent       Message[]        @relation("MessageSender")
  conversationReads  ConversationRead[]
  expenses           Expense[]        @relation("ExpenseCreator")
  expensesApproved   Expense[]        @relation("ExpenseApprover")
  tasksAssigned      Task[]           @relation("TaskAssignee")
  tasksCreated       Task[]           @relation("TaskCreator")
  tasksApproved      Task[]           @relation("TaskApprover")
  contractAttachments ContractAttachment[] @relation("ContractAttachmentUploader")
  contractsDeleted    Contract[]           @relation("ContractDeletedBy")
  pushSubscriptions   PushSubscription[]
  telegramChatId      String?          @unique @map("telegram_chat_id")
  /** Значок в списке команды (задают ADMIN / SUPER_ADMIN): ключ иконки, например star, trophy */
  badgeIcon           String?          @map("badge_icon")
  /** HEX цвет значка, например #22609A */
  badgeColor          String?          @map("badge_color")
  /** Произвольная подпись медали (как тег SVIP): «упорный», «лентяй» и т.д. */
  badgeLabel          String?          @map("badge_label")
  clientNotes         ClientNote[]
  clientStockEventsAuthored ClientStockEvent[] @relation("ClientStockEventAuthor")
  loadingAssignments  Deal[]           @relation("DealLoadingAssignee")
  deliveryAssignments Deal[]           @relation("DealDeliveryDriver")
  aiChats             AiChat[]
  aiTrainingRules     AiTrainingRule[] @relation("AiTrainingRuleAuthor")
  medalHistory        UserMedalHistory[] @relation("MedalHistoryUser")
  medalsGranted       UserMedalHistory[] @relation("MedalHistoryGrantedBy")
  medalsRemoved       UserMedalHistory[] @relation("MedalHistoryRemovedBy")
  monthlyGoals        UserMonthlyGoal[]
  monthlyGoalsUpdated UserMonthlyGoal[] @relation("UserMonthlyGoalUpdatedBy")
  notesBoardRowsAuthored NotesBoardRow[] @relation("NotesBoardAuthor")
  notesBoardEditRequests NotesBoardEditRequest[] @relation("NotesBoardRequester")
  importOrdersCreated    ImportOrder[]          @relation("ImportOrderCreator")
  importOrderAttachmentsUploaded ImportOrderAttachment[] @relation("ImportOrderAttachmentUploader")

  @@map("users")
}

/** Запись в истории медали пользователя (суперадмин может скрыть запись). */
model UserMedalHistory {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  badgeLabel   String?   @map("badge_label")
  badgeIcon    String?   @map("badge_icon")
  badgeColor   String?   @map("badge_color")
  grantedAt    DateTime  @default(now()) @map("granted_at")
  grantedById  String?   @map("granted_by_id")
  removedAt    DateTime? @map("removed_at")
  removedById  String?   @map("removed_by_id")

  user      User  @relation("MedalHistoryUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("MedalHistoryGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  removedBy User? @relation("MedalHistoryRemovedBy", fields: [removedById], references: [id], onDelete: SetNull)

  @@index([userId, grantedAt])
  @@map("user_medal_history")
}

/** Цели пользователя на конкретный месяц (сделки, выручка, заметки обзвона). */
model UserMonthlyGoal {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  year            Int
  month           Int
  dealsTarget     Int?     @map("deals_target")
  revenueTarget   Decimal? @map("revenue_target") @db.Decimal(15, 2)
  callNotesTarget Int?     @map("call_notes_target")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedById     String?  @map("updated_by_id")

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedBy User? @relation("UserMonthlyGoalUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([userId, year, month])
  @@index([year, month])
  @@map("user_monthly_goals")
}

model Session {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  refreshTokenHash     String    @unique @map("refresh_token_hash")
  expiresAt            DateTime  @map("expires_at")
  revokedAt            DateTime? @map("revoked_at")
  replacedBySessionId  String?   @map("replaced_by_session_id")
  lastUsedAt           DateTime? @map("last_used_at")
  ip                   String?
  userAgent            String?   @map("user_agent")
  createdAt            DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ==================== CLIENTS ====================

model Client {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  contactName String   @map("contact_name")
  phone       String?
  email       String?
  address     String?
  latitude    Float?
  longitude   Float?
  notes       String?
  inn         String?
  bankName    String?  @map("bank_name")
  bankAccount String?  @map("bank_account")
  mfo         String?
  vatRegCode  String?  @map("vat_reg_code")
  oked        String?
  portraitProfile     String?  @map("portrait_profile") @db.Text
  portraitGoals       String?  @map("portrait_goals") @db.Text
  portraitPains       String?  @map("portrait_pains") @db.Text
  portraitFears       String?  @map("portrait_fears") @db.Text
  portraitObjections  String?  @map("portrait_objections") @db.Text
  managerId   String   @map("manager_id")
  isSvip      Boolean  @default(false) @map("is_svip")
  creditStatus ClientCreditStatus @default(NORMAL) @map("credit_status")
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  manager     User         @relation("ClientManager", fields: [managerId], references: [id])
  deals       Deal[]
  contracts   Contract[]
  payments    Payment[]
  clientNotes ClientNote[]
  notesBoardRows NotesBoardRow[]
  stockPositions ClientStockPosition[]
  stockEvents ClientStockEvent[]

  @@index([managerId, isArchived])
  @@index([isArchived])
  @@map("clients")
}

model ClientNote {
  id        String    @id @default(uuid())
  clientId  String    @map("client_id")
  userId    String    @map("user_id")
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([clientId, deletedAt])
  @@index([clientId, createdAt])
  @@map("client_notes")
}

// ==================== CONTRACTS ====================

model Contract {
  id             String    @id @default(uuid())
  clientId       String    @map("client_id")
  contractNumber String    @unique @map("contract_number")
  contractType   ContractType @default(ONE_TIME) @map("contract_type")
  amount         Decimal   @default(0) @db.Decimal(14, 2)
  startDate      DateTime  @map("start_date")
  endDate        DateTime? @map("end_date")
  isActive       Boolean   @default(true) @map("is_active")
  notes          String?
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")
  deleteReason   String?   @map("delete_reason")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  client    Client  @relation(fields: [clientId], references: [id])
  deletedBy User?   @relation("ContractDeletedBy", fields: [deletedById], references: [id])
  deals     Deal[]
  attachments ContractAttachment[]
  powersOfAttorney PowerOfAttorney[]

  @@index([clientId])
  @@index([deletedAt])
  @@map("contracts")
}

model ContractAttachment {
  id         String   @id @default(uuid())
  contractId String   @map("contract_id")
  filename   String
  path       String
  mimeType   String   @map("mime_type")
  size       Int
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  uploader User     @relation("ContractAttachmentUploader", fields: [uploadedBy], references: [id])

  @@index([contractId])
  @@map("contract_attachments")
}

model PowerOfAttorney {
  id                       String       @id @default(uuid())
  contractId               String       @map("contract_id")
  poaNumber                String       @unique @map("poa_number")
  poaType                  ContractType @map("poa_type")
  authorizedPersonName     String       @map("authorized_person_name")
  authorizedPersonInn      String?      @map("authorized_person_inn")
  authorizedPersonPosition String?      @map("authorized_person_position")
  validFrom                DateTime     @map("valid_from")
  validUntil               DateTime     @map("valid_until")
  items                    Json?
  notes                    String?
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@map("powers_of_attorney")
}

// ==================== DEALS ====================

model Deal {
  id            String        @id @default(uuid())
  title         String
  status        DealStatus    @default(NEW)
  amount        Decimal       @default(0) @db.Decimal(12, 2)
  clientId      String        @map("client_id")
  managerId     String        @map("manager_id")
  contractId    String?       @map("contract_id")
  paymentMethod PaymentMethod? @map("payment_method")
  paymentType   PaymentType   @default(FULL) @map("payment_type")
  paidAmount    Decimal       @default(0) @db.Decimal(12, 2) @map("paid_amount")
  dueDate       DateTime?     @map("due_date")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  includeVat    Boolean       @default(true) @map("include_vat")
  terms         String?
  transferInn   String?       @map("transfer_inn")
  transferDocuments String?   @map("transfer_documents")
  transferType  String?       @map("transfer_type")
  isArchived    Boolean       @default(false) @map("is_archived")
  archivedAt    DateTime?     @map("archived_at")
  archivedById  String?       @map("archived_by_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  /** Момент перевода в CLOSED — для выручки по дню закрытия (если нет deal_date у позиций) */
  closedAt      DateTime?     @map("closed_at")
  /**
   * Сессионная сделка (внутренние цеха и т.п.): одна карточка на период; в аналитике выручка
   * по дате позиции (deal_date / created_at строки) до закрытия сделки.
   */
  isSessionDeal Boolean       @default(false) @map("is_session_deal")
  version       Int           @default(1)
  updatedAt     DateTime      @updatedAt @map("updated_at")

  /** CRM → Telegram group: warehouse queue (once per deal) */
  sentToWarehouse   Boolean @default(false) @map("sent_to_warehouse_tg")
  /** message_id поста в группе склада (для правок при изменении сделки) */
  warehouseTelegramMessageId String? @map("warehouse_telegram_message_id")
  /** CRM → Telegram group: production / quantities (once per deal) */
  sentToProduction  Boolean @default(false) @map("sent_to_production_tg")
  /** message_id последнего сообщения в группе производства (удаляем при уточнении способа оплаты) */
  productionTelegramMessageId String? @map("production_telegram_message_id")
  /** true — productionTelegramMessageId относится к TELEGRAM_GROUP_READY_FOR_SHIPMENT_CHAT_ID, иначе к группе производства */
  productionTelegramMessageInRfsChat Boolean @default(false) @map("production_telegram_message_in_rfs")
  /** CRM → Telegram группа производства: короткое «сделка принята» при ожидании склада (не ждём буха) */
  sentProductionIntakeTg Boolean @default(false) @map("sent_production_intake_tg")
  /** message_id того же поста «сделка принята» (для правок) */
  productionIntakeTelegramMessageId String? @map("production_intake_telegram_message_id")
  /** CRM → Telegram group: finance review (once per deal) */
  sentToFinance     Boolean @default(false) @map("sent_to_finance_tg")
  /** message_id поста в группе финансов (для правок после действий бухгалтера) */
  financeTelegramMessageId String? @map("finance_telegram_message_id")
  /** Накопленный текст событий внизу того же сообщения (plain, экранируется при отправке) */
  financeTelegramAppendix  String? @map("finance_telegram_appendix") @db.Text

  // ── Delivery / loading / driver workflow ──
  deliveryType       DeliveryType?     @map("delivery_type")
  vehicleNumber      String?           @map("delivery_vehicle_number")
  vehicleType        String?           @map("delivery_vehicle_type")
  deliveryComment    String?           @map("delivery_comment")
  loadingAssigneeId  String?           @map("loading_assignee_id")
  deliveryDriverId   String?           @map("delivery_driver_id")

  client             Client              @relation(fields: [clientId], references: [id])
  manager            User                @relation("DealManager", fields: [managerId], references: [id])
  contract           Contract?           @relation(fields: [contractId], references: [id])
  archivedBy         User?               @relation("DealArchivedBy", fields: [archivedById], references: [id])
  loadingAssignee    User?               @relation("DealLoadingAssignee", fields: [loadingAssigneeId], references: [id])
  deliveryDriver     User?               @relation("DealDeliveryDriver", fields: [deliveryDriverId], references: [id])
  comments           DealComment[]
  items              DealItem[]
  clientStockEvents  ClientStockEvent[]
  movements          InventoryMovement[]
  shipment           Shipment?
  payments           Payment[]
  messages           Message[]
  rating             DealRating?

  @@index([managerId, isArchived])
  @@index([clientId])
  @@index([contractId])
  @@index([status])
  @@index([status, createdAt])
  @@index([closedAt])
  @@index([isArchived])
  @@index([paymentStatus])
  @@index([loadingAssigneeId])
  @@index([deliveryDriverId])
  @@map("deals")
}

model DealItem {
  id               String          @id @default(uuid())
  dealId           String          @map("deal_id")
  productId        String          @map("product_id")
  requestedQty     Decimal?        @db.Decimal(12, 3) @map("requested_qty")
  price            Decimal?        @db.Decimal(12, 2)
  sourceOpType     String?         @map("source_op_type")
  lineTotal        Decimal?        @db.Decimal(15, 2) @map("line_total")
  closingBalance   Decimal?        @db.Decimal(15, 2) @map("closing_balance")
  isProblem        Boolean         @default(false) @map("is_problem")
  requestComment   String?         @map("request_comment")
  warehouseComment String?         @map("warehouse_comment")
  confirmedBy      String?         @map("confirmed_by")
  confirmedAt      DateTime?       @map("confirmed_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  dealDate         DateTime?       @map("deal_date")
  /** Факт отгрузки со склада (позиция) */
  shippedAt        DateTime?       @map("shipped_at")
  /** Факт доставки клиенту (позиция) */
  deliveredAt      DateTime?       @map("delivered_at")

  deal      Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  confirmer User?   @relation("ItemConfirmedBy", fields: [confirmedBy], references: [id])

  @@index([dealId])
  @@index([isProblem])
  @@index([sourceOpType])
  @@index([dealDate])
  @@index([shippedAt])
  @@index([deliveredAt])
  @@map("deal_items")
}

model DealComment {
  id        String   @id @default(uuid())
  dealId    String   @map("deal_id")
  authorId  String   @map("author_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  deal   Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([dealId])
  @@map("deal_comments")
}

// ==================== SHIPMENT ====================

model Shipment {
  id                 String   @id @default(uuid())
  dealId             String   @unique @map("deal_id")
  vehicleType        String   @map("vehicle_type")
  vehicleNumber      String   @map("vehicle_number")
  driverName         String   @map("driver_name")
  departureTime      DateTime @map("departure_time")
  deliveryNoteNumber String   @map("delivery_note_number")
  shipmentComment    String?  @map("shipment_comment")
  shippedBy          String   @map("shipped_by")
  shippedAt          DateTime @default(now()) @map("shipped_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation("ShippedBy", fields: [shippedBy], references: [id])

  @@map("shipments")
}

// ==================== WAREHOUSE ====================

model Product {
  id              String   @id @default(uuid())
  name            String
  sku             String   @unique
  unit            String   @default("шт")
  format          String?
  category        String?
  countryOfOrigin String?  @map("country_of_origin")
  stock           Decimal  @default(0) @db.Decimal(12, 3)
  minStock        Decimal  @default(0) @db.Decimal(12, 3) @map("min_stock")
  purchasePrice   Decimal? @db.Decimal(12, 2) @map("purchase_price")
  salePrice       Decimal? @db.Decimal(12, 2) @map("sale_price")
  installmentPrice Decimal? @db.Decimal(12, 2) @map("installment_price")
  pricingMode     String   @default("PER_UNIT") @map("pricing_mode")
  specifications  Json?
  isActive        Boolean  @default(true) @map("is_active")
  manufacturedAt  DateTime? @map("manufactured_at")
  expiresAt       DateTime? @map("expires_at")
  supplierId      String?  @map("supplier_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  supplier  Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements InventoryMovement[]
  dealItems DealItem[]
  clientStockPositions ClientStockPosition[]
  clientStockEvents ClientStockEvent[]
  importOrderItems ImportOrderItem[]

  @@index([category])
  @@index([countryOfOrigin])
  @@index([supplierId])
  @@map("products")
}

model InventoryMovement {
  id        String       @id @default(uuid())
  productId String       @map("product_id")
  type      MovementType
  quantity  Decimal      @db.Decimal(12, 3)
  dealId    String?      @map("deal_id")
  /** Связь с событием «поступление на склад клиента» (тип ADD) для корректировок суперадмином */
  clientStockEventId String? @map("client_stock_event_id")
  note      String?
  createdBy String       @map("created_by")
  createdAt DateTime     @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])
  deal    Deal?   @relation(fields: [dealId], references: [id])
  clientStockEvent ClientStockEvent? @relation(fields: [clientStockEventId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([dealId])
  @@index([clientStockEventId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model ClientStockPosition {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  productId String   @map("product_id")
  qtyTotal  Decimal  @default(0) @db.Decimal(12, 3) @map("qty_total")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([clientId, productId])
  @@index([clientId])
  @@index([productId])
  @@map("client_stock_positions")
}

model ClientStockEvent {
  id           String              @id @default(uuid())
  clientId     String              @map("client_id")
  productId    String              @map("product_id")
  type         ClientStockEventType
  qtyDelta     Decimal             @db.Decimal(12, 3) @map("qty_delta")
  qtyBefore    Decimal             @db.Decimal(12, 3) @map("qty_before")
  qtyAfter     Decimal             @db.Decimal(12, 3) @map("qty_after")
  unitPrice    Decimal?            @db.Decimal(12, 2) @map("unit_price")
  lineTotal    Decimal?            @db.Decimal(15, 2) @map("line_total")
  sourceDealId String?             @map("source_deal_id")
  authorId     String              @map("author_id")
  comment      String?
  createdAt    DateTime            @default(now()) @map("created_at")

  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
  sourceDeal Deal?    @relation(fields: [sourceDealId], references: [id], onDelete: SetNull)
  author     User     @relation("ClientStockEventAuthor", fields: [authorId], references: [id])
  inventoryMovements InventoryMovement[]

  @@index([clientId, createdAt])
  @@index([clientId, productId])
  @@index([sourceDealId])
  @@index([authorId])
  @@map("client_stock_events")
}

// ==================== AUDIT ====================

model AuditLog {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id")
  before     Json?
  after      Json?
  reason     String?
  createdAt  DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== NOTIFICATIONS ====================

model NotificationBatch {
  id              String   @id @default(uuid())
  createdByUserId String   @map("created_by_user_id")
  targetType      String   @map("target_type")
  targetPayload   Json     @map("target_payload")
  title           String
  recipientCount  Int      @default(0) @map("recipient_count")
  createdAt       DateTime @default(now()) @map("created_at")

  createdBy     User           @relation("BatchCreatedBy", fields: [createdByUserId], references: [id])
  notifications Notification[]

  @@index([createdByUserId, createdAt])
  @@map("notification_batches")
}

model Notification {
  id              String               @id @default(uuid())
  userId          String               @map("user_id")
  title           String
  body            String
  severity        NotificationSeverity @default(INFO)
  link            String?
  isRead          Boolean              @default(false) @map("is_read")
  readAt          DateTime?            @map("read_at")
  createdByUserId String               @map("created_by_user_id")
  batchId         String?              @map("batch_id")
  createdAt       DateTime             @default(now()) @map("created_at")

  user      User               @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User               @relation("NotificationSender", fields: [createdByUserId], references: [id])
  batch     NotificationBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([batchId])
  @@map("notifications")
}

// ==================== PAYMENTS ====================

model Payment {
  id        String   @id @default(uuid())
  dealId    String   @map("deal_id")
  clientId  String   @map("client_id")
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @default(now()) @map("paid_at")
  method    String?
  note      String?
  createdBy String   @map("created_by")
  receivedById String? @map("received_by_id")
  createdAt DateTime @default(now()) @map("created_at")

  deal       Deal   @relation(fields: [dealId], references: [id])
  client     Client @relation(fields: [clientId], references: [id])
  creator    User   @relation("PaymentCreator", fields: [createdBy], references: [id])
  receivedBy User?  @relation("PaymentReceiver", fields: [receivedById], references: [id])

  @@index([dealId])
  @@index([clientId, paidAt])
  @@index([paidAt])
  @@map("payments")
}

// ==================== MESSAGES (Chat) ====================

model Message {
  id               String           @id @default(uuid())
  conversationType ConversationType @map("conversation_type")
  senderId         String           @map("sender_id")
  text             String
  dealId           String?          @map("deal_id")
  replyToId        String?          @map("reply_to_id")
  editedAt         DateTime?        @map("edited_at")
  isDeleted        Boolean          @default(false) @map("is_deleted")
  createdAt        DateTime         @default(now()) @map("created_at")

  sender  User     @relation("MessageSender", fields: [senderId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])
  replyTo Message? @relation("MessageReply", fields: [replyToId], references: [id])
  replies Message[] @relation("MessageReply")
  attachments MessageAttachment[]

  @@index([conversationType, createdAt])
  @@index([senderId])
  @@index([dealId])
  @@map("messages")
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  filename  String
  path      String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

model ConversationRead {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  conversationType ConversationType @map("conversation_type")
  lastReadAt       DateTime         @default(now()) @map("last_read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationType])
  @@map("conversation_reads")
}

// ==================== EXPENSES ====================

model Expense {
  id             String    @id @default(uuid())
  date           DateTime  @db.Date
  category       String
  amount         Decimal   @db.Decimal(12, 2)
  note           String?
  method         String?
  status         String    @default("APPROVED")
  approvedBy     String?   @map("approved_by")
  approvedAt     DateTime? @map("approved_at")
  rejectedReason String?   @map("rejected_reason")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")

  /** Валюта расхода (NULL = UZS, трактуется как базовая валюта). MVP-4. */
  currency       String?
  /** Курс ЦБ на дату расхода (UZS за 1 единицу). MVP-4. */
  exchangeRate   Decimal?  @db.Decimal(15, 6) @map("exchange_rate")
  /** Эквивалент суммы в UZS. Если currency=UZS или NULL, равно amount. MVP-4. */
  amountUzs      Decimal?  @db.Decimal(14, 2) @map("amount_uzs")
  /** Привязка к импорт-заказу для расчёта landed cost. MVP-4. */
  importOrderId  String?   @map("import_order_id")

  creator     User         @relation("ExpenseCreator", fields: [createdBy], references: [id])
  approver    User?        @relation("ExpenseApprover", fields: [approvedBy], references: [id])
  importOrder ImportOrder? @relation("ImportOrderExpenses", fields: [importOrderId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([category])
  @@index([status])
  @@index([method])
  @@index([importOrderId])
  @@map("expenses")
}

// ==================== TASKS ====================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  APPROVED
}

enum CallResult {
  ANSWERED
  NO_ANSWER
}

model Task {
  id           String      @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus  @default(TODO)
  color        String?     @map("color")
  checklist    Json?       @map("checklist")
  assigneeId   String      @map("assignee_id")
  createdById  String      @map("created_by_id")
  report       String?
  dueDate      DateTime?   @map("due_date")
  plannedDate  DateTime?   @map("planned_date")
  approvedById String?     @map("approved_by_id")
  approvedAt   DateTime?   @map("approved_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  assignee    User             @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy   User             @relation("TaskCreator", fields: [createdById], references: [id])
  approvedBy  User?            @relation("TaskApprover", fields: [approvedById], references: [id])
  attachments TaskAttachment[]

  @@index([assigneeId, status])
  @@index([createdById])
  @@index([plannedDate, status])
  @@map("tasks")
}

model NotesBoardRow {
  id          String     @id @default(uuid())
  clientId    String     @map("client_id")
  authorId    String     @map("author_id")
  callResult  CallResult @map("call_result")
  status      String?
  comment     String     @db.Text
  editRequestCount Int   @default(0) @map("edit_request_count")
  lastEditRequestComment String? @map("last_edit_request_comment") @db.Text
  lastEditRequestByName String? @map("last_edit_request_by_name")
  lastEditRequestAt DateTime? @map("last_edit_request_at")
  lastCallAt  DateTime   @map("last_call_at")
  nextCallAt  DateTime?  @map("next_call_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User   @relation("NotesBoardAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  editRequests NotesBoardEditRequest[]

  @@index([clientId, lastCallAt])
  @@index([authorId, createdAt])
  @@index([nextCallAt])
  @@map("notes_board_rows")
}

model NotesBoardEditRequest {
  id          String   @id @default(uuid())
  rowId       String   @map("row_id")
  requesterId String   @map("requester_id")
  comment     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  row       NotesBoardRow @relation(fields: [rowId], references: [id], onDelete: Cascade)
  requester User          @relation("NotesBoardRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([rowId, createdAt])
  @@index([requesterId, createdAt])
  @@map("notes_board_edit_requests")
}

model TaskAttachment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  filename  String
  path      String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_attachments")
}

// ==================== DEAL RATINGS (QR-based customer feedback) ====================

model DealRating {
  id        String    @id @default(uuid())
  dealId    String    @unique @map("deal_id")
  token     String    @unique
  rating    Int?
  comment   String?
  ratedAt   DateTime? @map("rated_at")
  createdAt DateTime  @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("deal_ratings")
}

// ==================== COMPANY SETTINGS ====================

model CompanySettings {
  id           String   @id @default("singleton")
  companyName  String   @default("") @map("company_name")
  inn          String   @default("")
  address      String   @default("")
  phone        String   @default("")
  email        String   @default("")
  bankName     String   @default("") @map("bank_name")
  bankAccount  String   @default("") @map("bank_account")
  mfo          String   @default("")
  director     String   @default("")
  logoPath     String?  @map("logo_path")
  vatRegCode   String   @default("") @map("vat_reg_code")
  oked                String   @default("")
  monthlyRevenueGoal  Float    @default(250000000) @map("monthly_revenue_goal")
  balanceStartDate    DateTime? @db.Date @map("balance_start_date")
